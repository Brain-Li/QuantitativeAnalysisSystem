# 服务端口（与前端 vite 代理一致时可保持 8787）
PORT=8787

# SQLite 数据库文件路径（相对 server 目录）
DATABASE_PATH=./data/app.db

# 首次启动且无用户表数据时，自动创建管理员（用户名见 ADMIN_USER）
# 须为强密码（建议至少 8 位且含字母+数字）；勿将含真实密码的 .env 提交到 Git
ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=

# 管理员「重置密码」时使用的默认密码（须满足至少 8 位且含字母+数字）；不设置则每次随机生成
# DEFAULT_RESET_PASSWORD=

# 可选：关闭鉴权（仅本地调试，切勿用于公网）
# DISABLE_AUTH=0
